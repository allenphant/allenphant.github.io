---
interface Props {
  name: string;
  bio: string | null;
  avatarUrl: string;
}

const { name, bio, avatarUrl } = Astro.props;
---

<section class="relative py-32 lg:py-40">
  <div class="section-container">
    <div class="max-w-2xl">
      <!-- Greeting -->
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-full overflow-hidden ring-1 ring-[#D9D0C8]">
          <img src={avatarUrl} alt={name || "Avatar"} class="w-full h-full object-cover" loading="eager" />
        </div>
        <span class="text-sm text-[#9CA3AF] font-light tracking-wider">Hello, I'm</span>
      </div>

      <!-- Name -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-serif italic font-light tracking-tight text-[#2D2D2D] mb-4">
        {name || "allenphant"}
      </h1>

      <!-- Typing effect roles -->
      <div class="h-8 mb-8">
        <span class="text-lg sm:text-xl text-[#9CA3AF] font-light tracking-wide">
          <span id="typed-text"></span><span class="text-[#C5A059] motion-safe:animate-pulse">|</span>
        </span>
      </div>

      <!-- Bio -->
      {bio && (
        <p class="text-base text-[#5A5A5A] max-w-xl leading-relaxed mb-10 font-light">
          {bio}
        </p>
      )}

      <!-- Divider -->
      <div class="w-12 h-px bg-[#D9D0C8] mb-10"></div>

      <!-- CTA buttons -->
      <div class="flex flex-wrap gap-3">
        <a
          href="/projects"
          class="px-6 py-2.5 bg-[#2D2D2D] hover:bg-[#404040] text-white text-sm font-light tracking-wide rounded-[4px] transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-[#2D2D2D] focus:ring-offset-2"
        >
          View Projects
        </a>
        <a
          href="/contact"
          class="px-6 py-2.5 border border-[#D9D0C8] hover:border-[#2D2D2D] text-[#5A5A5A] hover:text-[#2D2D2D] text-sm font-light tracking-wide rounded-[4px] transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#2D2D2D] focus:ring-offset-2"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const roles = [
    "Automation Enthusiast",
    "Python Scripting for Life",
    "Wet Lab meets Dry Lab",
    "Saving Time, One Script at a Time",
  ];

  const typedEl = document.getElementById("typed-text");

  if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    if (typedEl) typedEl.textContent = roles[0];
  } else {
    let roleIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    let timer: number;

    function type() {
      if (!typedEl) return;

      const currentRole = roles[roleIndex];

      if (isDeleting) {
        typedEl.textContent = currentRole.substring(0, charIndex - 1);
        charIndex--;
      } else {
        typedEl.textContent = currentRole.substring(0, charIndex + 1);
        charIndex++;
      }

      let delay = isDeleting ? 40 : 80;

      if (!isDeleting && charIndex === currentRole.length) {
        delay = 2000;
        isDeleting = true;
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
        delay = 400;
      }

      timer = window.setTimeout(type, delay);
    }

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        clearTimeout(timer);
      } else {
        type();
      }
    });

    type();
  }
</script>
