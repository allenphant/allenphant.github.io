---
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchUserProfile } from "../lib/github";

let profile = null;

try {
  profile = await fetchUserProfile();
} catch (e) {
  console.error("Failed to fetch profile:", e);
}

// Customize your experience timeline here
const experiences = [
  {
    title: "M.S. in Biochemical Science & Technology",
    company: "National Taiwan University (NTU)",
    period: "2023 - 2026",
    description: "Research focus: Lab Automation, Single-cell Sequencing (Drop-seq/10x), Bio-Image Analysis. Built Python tools to automate tedious lab workflows and image processing.",
  },
  {
    title: "B.S. in Biochemical Science & Technology",
    company: "National Taiwan University (NTU)",
    period: "2019 - 2023",
    description: "Built a foundation in molecular biology, cell biology, and biochemistry. Started applying programming to lab workflows.",
  },
];
---

<BaseLayout title="About" description="Learn more about Allen — NTU Biochem M.S., lab automation, and Python scripting.">
  <section class="py-24">
    <div class="section-container">
      <div class="max-w-3xl">
        {/* Header */}
        <div class="flex items-center gap-6 mb-12">
          <div class="w-24 h-24 rounded-2xl overflow-hidden ring-2 ring-primary-500/20">
            <img
              src={profile?.avatarUrl || "https://github.com/allenphant.png"}
              alt="Profile"
              class="w-full h-full object-cover"
            />
          </div>
          <div>
            <h1 class="text-4xl font-bold text-white mb-1" style="font-family: var(--font-heading);">{profile?.name || "allenphant"}</h1>
            {profile?.location && (
              <p class="text-gray-400 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {profile.location}
              </p>
            )}
          </div>
        </div>

        {/* Bio */}
        <div class="glass p-8 mb-12">
          <h2 class="text-xl font-semibold text-white mb-4">About Me</h2>
          <div class="text-gray-300 leading-relaxed space-y-4">
            <p>
              {profile?.bio || "M.S. in Biochemical Science & Technology from National Taiwan University (graduated Feb 2026)."}
            </p>
            <p>
              With a background in molecular biology and bioinformatics tools,
              I also love writing code to solve everyday problems — whether it's automating
              tedious lab workflows, building chatbots, or scripting game tools.
              I enjoy the process of identifying inefficiencies and building something to fix them.
            </p>
          </div>
        </div>


        {/* Experience Timeline */}
        <div class="border-t border-white/5 pt-12 mb-12">
          <h2 class="text-xl font-semibold text-white mb-8">Experience</h2>
          <div class="relative">
            {/* Timeline line */}
            <div class="absolute left-4 top-0 bottom-0 w-px bg-gradient-to-b from-primary-500/50 via-primary-500/20 to-transparent"></div>

            <div class="space-y-8">
              {experiences.map((exp, i) => (
                <div class="relative pl-12">
                  {/* Timeline dot */}
                  <div class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full bg-primary-500 ring-4 ring-surface-950"></div>

                  <div class="glass p-6">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-2">
                      <h3 class="text-lg font-semibold text-white">{exp.title}</h3>
                      <span class="text-xs text-primary-400 font-mono">{exp.period}</span>
                    </div>
                    <p class="text-sm text-gray-400 mb-2">{exp.company}</p>
                    <p class="text-sm text-gray-400 leading-relaxed">{exp.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* Links */}
        <div class="border-t border-white/5 pt-12 flex flex-wrap gap-4">
          <a
            href="/resume.pdf"
            target="_blank"
            class="px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white font-medium rounded-xl transition-all shadow-lg shadow-primary-600/25 hover:shadow-primary-500/40 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-surface-950 flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download Resume
          </a>
          <a
            href={profile?.url || "https://github.com/allenphant"}
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 glass-hover text-gray-300 font-medium focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-surface-950 flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            GitHub Profile
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
