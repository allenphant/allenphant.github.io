---
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchUserProfile } from "../lib/github";
import FrierenLiquidText from "../components/FrierenLiquidText";

let profile = null;

try {
  profile = await fetchUserProfile();
} catch (e) {
  console.error("Failed to fetch profile:", e);
}

const experiences = [
  {
    title: "M.S. in Biochemical Science & Technology",
    company: "National Taiwan University (NTU)",
    period: "2023 - 2026",
    description: "Research focus: Lab Automation, Single-cell Sequencing (Drop-seq/10x), Bio-Image Analysis. Built Python tools to automate tedious lab workflows and image processing.",
  },
  {
    title: "B.S. in Biochemical Science & Technology",
    company: "National Taiwan University (NTU)",
    period: "2019 - 2023",
    description: "Built a foundation in molecular biology, cell biology, and biochemistry. Started applying programming to lab workflows.",
  },
];
---

<BaseLayout title="About" description="Learn more about Allen — NTU Biochem M.S., lab automation, and Python scripting.">

  {/* Profile header */}
  <div class="section-container pt-8 pb-6">
    <div class="max-w-2xl">
      <div class="flex items-center gap-5">
        <div class="w-20 h-20 rounded-full overflow-hidden ring-1 ring-[#D9D0C8] shrink-0">
          <img
            src={profile?.avatarUrl || "https://github.com/allenphant.png"}
            alt="Profile"
            class="w-full h-full object-cover"
          />
        </div>
        <div>
          <h1 class="text-3xl font-serif italic font-light text-[#2D2D2D] mb-1 tracking-wide">{profile?.name || "allenphant"}</h1>
          {profile?.location && (
            <p class="text-sm text-[#9CA3AF] font-light flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {profile.location}
            </p>
          )}
        </div>
      </div>
    </div>
  </div>

  {/* Interactive bio canvas — height auto-determined by canvas (1.4×vh) */}
  <section style="position: relative;">
    <FrierenLiquidText client:only="react" />
  </section>

  {/* Experience + Links (scroll down) */}
  <section class="py-8 lg:py-10">
    <div class="section-container">
      <div class="max-w-2xl">

        {/* Experience Timeline */}
        <div class="border-t border-[#D9D0C8] pt-12 mb-12">
          <h2 class="text-xs font-light uppercase tracking-widest text-[#9CA3AF] mb-8">Experience</h2>
          <div class="relative">
            <div class="absolute left-4 top-0 bottom-0 w-px bg-[#D9D0C8]"></div>
            <div class="space-y-8">
              {experiences.map((exp) => (
                <div class="relative pl-12">
                  <div class="absolute left-[13px] top-1.5 w-2 h-2 rounded-full bg-[#2D2D2D] ring-4 ring-white"></div>
                  <div class="card p-6">
                    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
                      <h3 class="text-sm font-normal text-[#2D2D2D] leading-snug">{exp.title}</h3>
                      <span class="text-xs text-[#9CA3AF] font-mono shrink-0">{exp.period}</span>
                    </div>
                    <p class="text-xs text-[#C5A059] mb-2 font-light">{exp.company}</p>
                    <p class="text-sm text-[#5A5A5A] leading-relaxed font-light">{exp.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* Links */}
        <div class="border-t border-[#D9D0C8] pt-12 flex flex-wrap gap-3">
          <a
            href="/resume.pdf"
            target="_blank"
            class="px-6 py-2.5 bg-[#2D2D2D] hover:bg-[#404040] text-white text-sm font-light tracking-wide rounded-[4px] transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-[#2D2D2D] focus:ring-offset-2 flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download Resume
          </a>
          <a
            href={profile?.url || "https://github.com/allenphant"}
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-2.5 border border-[#D9D0C8] hover:border-[#2D2D2D] text-[#5A5A5A] hover:text-[#2D2D2D] text-sm font-light tracking-wide rounded-[4px] transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#2D2D2D] focus:ring-offset-2 flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            GitHub Profile
          </a>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
